# PHPStan baseline — pre-existing findings, captured so new code is held to a
# clean bar (the CI job fails on any NEW error). Fix entries over time and
# regenerate with `composer phpstan:baseline` (or run the phpstan-baseline
# workflow and commit the artifact). Do not hand-edit.
parameters:
	ignoreErrors:
		-
			message: '#^Variable \$block might not be defined\.$#'
			identifier: variable.undefined
			count: 1
			path: blocks/comment-form/render.php

		-
			message: '#^Variable \$block might not be defined\.$#'
