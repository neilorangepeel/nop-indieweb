{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "nop-indieweb/webmentions",
	"title": "Webmentions",
	"description": "Displays likes, reposts, and replies received via webmention for this post.",
	"category": "theme",
	"icon": "heart",
	"keywords": ["webmention", "likes", "replies", "indieweb", "bridgy"],
	"editorScript": "file:./editor.js",
	"style": "file:./style.css",
	"render": "file:./render.php",
	"usesContext": ["postId", "postType"],
	"supports": {
		"html": false,
		"align": false,
		"spacing": {
			"margin": true
		}
	}
}
