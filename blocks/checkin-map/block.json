{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "nop-indieweb/checkin-map",
	"title": "Checkin Map",
	"description": "Static map image for a checkin post with OpenStreetMap link. Outputs hidden mf2 latitude/longitude data elements.",
	"category": "nop-indieweb-meta",
	"icon": "location-alt",
	"keywords": ["checkin", "map", "location", "geoapify", "openstreetmap"],
	"editorScript": "file:./editor.js",
	"style": "nop-blocks-shared",
	"render": "file:./render.php",
	"usesContext": ["postId", "postType"],
	"supports": {
		"html": false,
		"align": false,
		"color": {
			"background": true,
			"gradient": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		}
	}
}
