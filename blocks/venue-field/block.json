{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "nop-indieweb/venue-field",
	"title": "Venue Field (deprecated)",
	"description": "Displays a single venue data field (address, city, country) for a checkin post. Pick the field from the block inspector.",
	"category": "nop-indieweb-meta",
	"icon": "location",
	"keywords": ["checkin", "venue", "address", "city", "country", "location", "indieweb"],
	"editorScript": "file:./editor.js",
	"style": "nop-blocks-shared",
	"render": "file:./render.php",
	"usesContext": ["postId", "postType"],
	"attributes": {
		"field": {
			"type": "string",
			"default": "address"
		}
	},
	"supports": {
		"inserter": false,
		"html": false,
		"align": false,
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"__experimentalFontFamily": true,
			"__experimentalFontStyle": true,
			"__experimentalFontWeight": true,
			"__experimentalLetterSpacing": true,
			"__experimentalTextDecoration": true,
			"__experimentalTextTransform": true,
			"__experimentalDefaultControls": {
				"fontSize": true,
				"lineHeight": true,
				"__experimentalFontFamily": true,
				"__experimentalFontStyle": true,
				"__experimentalFontWeight": true,
				"__experimentalLetterSpacing": true,
				"__experimentalTextDecoration": true,
				"__experimentalTextTransform": true
			}
		},
		"color": {
			"text": true,
			"background": true,
			"gradients": true,
			"link": false,
			"__experimentalDefaultControls": {
				"text": true,
				"background": true
			}
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalDefaultControls": {
				"margin": true,
				"padding": true
			}
		}
	}
}
