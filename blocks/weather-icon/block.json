{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "nop-indieweb/weather-icon",
	"title": "Weather Icon",
	"description": "Renders the weather icon for a check-in post based on stored conditions. Picks one of ten Phosphor SVGs based on the nop_indieweb_weather_icon meta value.",
	"category": "nop-indieweb-meta",
	"icon": "cloud",
	"keywords": ["weather", "checkin", "icon", "indieweb"],
	"editorScript": "file:./editor.js",
	"style": "nop-blocks-shared",
	"render": "file:./render.php",
	"usesContext": ["postId", "postType"],
	"supports": {
		"html": false,
		"align": false,
		"typography": {
			"fontSize": true,
			"__experimentalDefaultControls": {
				"fontSize": true
			}
		},
		"color": {
			"text": true,
			"background": true,
			"gradients": false,
			"link": false,
			"__experimentalDefaultControls": {
				"text": true
			}
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalDefaultControls": {
				"margin": true,
				"padding": true
			}
		}
	}
}
