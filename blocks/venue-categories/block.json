{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "nop-indieweb/venue-categories",
	"title": "Venue Categories (deprecated)",
	"description": "Renders Foursquare venue categories as inline pills with mf2 p-category markup.",
	"category": "nop-indieweb-meta",
	"icon": "tag",
	"keywords": ["checkin", "venue", "categories", "foursquare", "indieweb"],
	"editorScript": "file:./editor.js",
	"style": "nop-blocks-shared",
	"render": "file:./render.php",
	"usesContext": ["postId", "postType"],
	"supports": {
		"inserter": false,
		"html": false,
		"align": false,
		"typography": {
			"fontSize": true,
			"lineHeight": true,
			"__experimentalFontFamily": true,
			"__experimentalFontStyle": true,
			"__experimentalFontWeight": true,
			"__experimentalLetterSpacing": true,
			"__experimentalTextDecoration": true,
			"__experimentalTextTransform": true,
			"__experimentalDefaultControls": {
				"fontSize": true,
				"lineHeight": true,
				"__experimentalFontFamily": true,
				"__experimentalFontStyle": true,
				"__experimentalFontWeight": true,
				"__experimentalLetterSpacing": true,
				"__experimentalTextDecoration": true,
				"__experimentalTextTransform": true
			}
		},
		"color": {
			"text": true,
			"background": true,
			"gradients": true,
			"__experimentalDefaultControls": {
				"text": true,
				"background": true
			}
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"__experimentalDefaultControls": {
				"margin": true,
				"padding": true
			}
		}
	}
}
