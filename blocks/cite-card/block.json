{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "nop-indieweb/cite-card",
	"title": "Cite Card",
	"description": "Displays the captured context for a like, bookmark, reply, or repost — title linked to source, author, and excerpt.",
	"category": "nop-indieweb-conversations",
	"icon": "external",
	"editorScript": "file:./editor.js",
	"style": [ "file:./style.css", "nop-blocks-shared" ],
	"render": "file:./render.php",
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"html": false,
		"multiple": false,
		"spacing": { "margin": true }
	}
}
